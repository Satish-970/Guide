          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/users/1/activate", "host": ["{{baseUrl}}"], "path": ["admin","users","1","activate"] }
          }
        }
      ]
    },

    {
      "name": "Citizen Service",
      "item": [
        {
          "name": "Create or Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Auth-UserId", "value": "1" }
            ],
            "url": { "raw": "{{baseUrl}}/citizens/profile", "host": ["{{baseUrl}}"], "path": ["citizens","profile"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"dateOfBirth\": \"1990-05-15\",\n  \"gender\": \"MALE\",\n  \"address\": \"12 Main Street, Coimbatore\",\n  \"contactInfo\": \"+91-9876543210\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Auth-UserId", "value": "1" }
            ],
            "url": { "raw": "{{baseUrl}}/citizens/profile", "host": ["{{baseUrl}}"], "path": ["citizens","profile"] }
          }
        },
        {
          "name": "Get All Citizens",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/citizens", "host": ["{{baseUrl}}"], "path": ["citizens"] }
          }
        },
        {
          "name": "Get Citizen by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/citizens/1", "host": ["{{baseUrl}}"], "path": ["citizens","1"] }
          }
        },
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/citizens/1/documents", "host": ["{{baseUrl}}"], "path": ["citizens","1","documents"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Get Citizen Documents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/citizens/1/documents", "host": ["{{baseUrl}}"], "path": ["citizens","1","documents"] }
          }
        },
        {
          "name": "Verify or Reject Document",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/citizens/documents/1/verify?status=VERIFIED",
              "host": ["{{baseUrl}}"],
              "path": ["citizens","documents","1","verify"],
              "query": [{ "key": "status", "value": "VERIFIED", "description": "PENDING | VERIFIED | REJECTED" }]
            }
          }
        },
        {
          "name": "[Internal] Auto-Create Citizen on Registration",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/citizens/internal/create", "host": ["{{baseUrl}}"], "path": ["citizens","internal","create"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"name\": \"John Doe\",\n  \"contactInfo\": \"+91-9876543210\"\n}"
            }
          }
        },
        {
          "name": "[Internal] Get Citizen by UserId",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/citizens/internal/user/1", "host": ["{{baseUrl}}"], "path": ["citizens","internal","user","1"] }
          }
        }
      ]
    },

