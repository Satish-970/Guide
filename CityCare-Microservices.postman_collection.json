{
  "info": {
    "name": "CityCare Microservices",
    "description": "Complete Postman collection for CityCare microservices. All requests route through the API Gateway at port 8080. Set the `token` variable after login to authenticate subsequent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",   "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register Citizen",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\",\n  \"phone\": \"+91-9876543210\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Admin - Create Doctor/Nurse",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/staff", "host": ["{{baseUrl}}"], "path": ["admin","staff"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Smith\",\n  \"email\": \"drsmith@citycare.com\",\n  \"password\": \"doctor123\",\n  \"phone\": \"+91-9000000001\",\n  \"role\": \"DOCTOR\"\n}"
            }
          }
        },
        {
          "name": "Admin - List All Staff",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/staff", "host": ["{{baseUrl}}"], "path": ["admin","staff"] }
          }
        },
        {
          "name": "Admin - Create Dispatcher",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/dispatchers", "host": ["{{baseUrl}}"], "path": ["admin","dispatchers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Dispatcher\",\n  \"email\": \"alice@citycare.com\",\n  \"password\": \"dispatch123\",\n  \"phone\": \"+91-9000000002\"\n}"
            }
          }
        },
        {
          "name": "Admin - List All Dispatchers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/dispatchers", "host": ["{{baseUrl}}"], "path": ["admin","dispatchers"] }
          }
        },
        {
          "name": "Admin - Create Compliance Officer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/compliance-officers", "host": ["{{baseUrl}}"], "path": ["admin","compliance-officers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Officer\",\n  \"email\": \"bob@citycare.com\",\n  \"password\": \"comply123\",\n  \"phone\": \"+91-9000000003\"\n}"
            }
          }
        },
        {
          "name": "Admin - Create Health Officer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/health-officers", "host": ["{{baseUrl}}"], "path": ["admin","health-officers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Carol Health\",\n  \"email\": \"carol@citycare.com\",\n  \"password\": \"health123\",\n  \"phone\": \"+91-9000000004\"\n}"
            }
          }
        },
        {
          "name": "Admin - List All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/users", "host": ["{{baseUrl}}"], "path": ["admin","users"] }
          }
        },
